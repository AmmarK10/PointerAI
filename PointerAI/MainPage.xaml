<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:shapes="clr-namespace:Microsoft.Maui.Controls.Shapes;assembly=Microsoft.Maui.Controls"
             x:Class="PointerAI.MainPage"
             BackgroundColor="#1F1F1D"
             Padding="0">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Style TargetType="Label">
                <Setter Property="FontFamily" Value="PoppinsRegular" />
            </Style>
            <Style TargetType="Entry">
                <Setter Property="FontFamily" Value="PoppinsRegular" />
            </Style>
            <Style TargetType="Button">
                <Setter Property="FontFamily" Value="PoppinsSemiBold" />
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid x:Name="RootLayout"
          BackgroundColor="#1F1F1D"
          Padding="0">

        <Grid x:Name="CharacterOnlyView"
              WidthRequest="150"
              HeightRequest="150"
              HorizontalOptions="Center"
              VerticalOptions="Center"
              BackgroundColor="Transparent">
            <Image x:Name="Character1Sprite"
                Source="character.png"
                WidthRequest="150"
                HeightRequest="150"
                Aspect="AspectFit"
                HorizontalOptions="Center"
                VerticalOptions="Center" />
            <Image x:Name="Character2Sprite"
                Source="character2.png"
                IsVisible="False"
                WidthRequest="150"
                HeightRequest="150"
                Aspect="AspectFit"
                HorizontalOptions="Center"
                VerticalOptions="Center" />
        </Grid>

        <Border x:Name="ChatPanel"
                IsVisible="False"
                Padding="0"
                BackgroundColor="#1F1F1D"
                Stroke="#3A3935"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 20"
                Opacity="0"
                Scale="0.95"
                VerticalOptions="Fill"
                HorizontalOptions="Fill">
            <Grid RowDefinitions="Auto,*,Auto"
                  BackgroundColor="#1F1F1D">

                <Grid Padding="28,16"
                      ColumnDefinitions="Auto,*,Auto,Auto"
                      ColumnSpacing="16"
                      BackgroundColor="#1F1F1D">
                    <Grid WidthRequest="42"
                          HeightRequest="42"
                          HorizontalOptions="Center"
                          VerticalOptions="Center">
                        <Image x:Name="HeaderCharacter1Image"
                            Source="character.png"
                            WidthRequest="42"
                            HeightRequest="42"
                            Aspect="AspectFit"
                            HorizontalOptions="Center"
                            VerticalOptions="Center" />
                        <Image x:Name="HeaderCharacter2Image"
                            Source="character2.png"
                            IsVisible="False"
                            WidthRequest="42"
                            HeightRequest="42"
                            Aspect="AspectFit"
                            HorizontalOptions="Center"
                            VerticalOptions="Center" />
                    </Grid>

                    <VerticalStackLayout Grid.Column="1"
                                         Spacing="2"
                                         VerticalOptions="Center">
                        <Label Text="Pointer AI"
                               FontFamily="PoppinsSemiBold"
                               FontSize="18"
                               TextColor="#F5F4ED" />
                        <Label Text="Screen conversation"
                               FontSize="12"
                               TextColor="#A8A69D" />
                    </VerticalStackLayout>

                    <Button Grid.Column="2"
                            Text="Settings"
                            Clicked="OnSettingsClicked"
                            Padding="14,8"
                            Margin="0,0,10,0"
                            BackgroundColor="#2B2B29"
                            TextColor="#D8D6CE"
                            CornerRadius="12"
                            FontSize="13"
                            VerticalOptions="Center" />

                    <Label x:Name="HotkeyBadge"
                           Grid.Column="3"
                           Text="Alt+Z"
                           Padding="10,5"
                           BackgroundColor="#2B2B29"
                           TextColor="#C7C5BC"
                           FontSize="13"
                           VerticalOptions="Center" />
                </Grid>

                <ScrollView x:Name="MessagesScrollView"
                            Grid.Row="1"
                            Padding="70,24">
                    <VerticalStackLayout x:Name="MessagesStack"
                                         Spacing="22"
                                         MaximumWidthRequest="820"
                                         HorizontalOptions="Center">
                        <Border Padding="0"
                                BackgroundColor="Transparent"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 18"
                                HorizontalOptions="Start"
                                MaximumWidthRequest="820">
                            <Label Text="Hi, I can help you find UI elements. What should I look for?"
                                   FontSize="17"
                                   TextColor="#F0EFE8"
                                   LineBreakMode="WordWrap" />
                        </Border>
                    </VerticalStackLayout>
                </ScrollView>

                <Grid Grid.Row="2"
                      Padding="70,14,70,24"
                      BackgroundColor="#1F1F1D">
                    <Border Padding="20,14"
                            WidthRequest="820"
                            HeightRequest="126"
                            MaximumWidthRequest="820"
                            HorizontalOptions="Center"
                            BackgroundColor="#2B2B29"
                            Stroke="#494842"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 26">
                        <Grid RowDefinitions="*,Auto" ColumnDefinitions="*,Auto">
                            <Entry x:Name="MessageEntry" Grid.ColumnSpan="2"
                                   Placeholder="How can I help you today?" BackgroundColor="Transparent"
                                   TextColor="#F5F4ED" PlaceholderColor="#A8A69D" ReturnType="Send"
                                   Completed="OnMessageEntryCompleted"
                                   FontSize="16"
                                   HorizontalOptions="Fill"
                                   VerticalOptions="Fill" />
                            <Button x:Name="SendButton" Grid.Row="1" Grid.Column="1" Text="↑" Clicked="OnSendClicked"
                                    WidthRequest="42" HeightRequest="42" Padding="0" BackgroundColor="#D97757"
                                    CornerRadius="14" FontSize="24" TextColor="#FFF8F3" />
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <Border x:Name="SettingsPanel"
                IsVisible="False"
                ZIndex="10"
                WidthRequest="480"
                Padding="28"
                BackgroundColor="#1A1C22"
                Stroke="#3F4350"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 20"
                HorizontalOptions="Center"
                VerticalOptions="Center">
            <VerticalStackLayout Spacing="16">
                <Label Text="Keyboard shortcuts"
                       FontFamily="PoppinsSemiBold"
                       FontSize="22"
                       TextColor="#F4F4F5" />
                <Label Text="Use modifiers plus one letter, number, or F-key."
                       FontSize="13"
                       TextColor="#9CA3AF" />

                <Label Text="Choose your character"
                       FontFamily="PoppinsSemiBold"
                       TextColor="#D4D4D8" />
                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <Border x:Name="Character1Option"
                            Padding="14,10"
                            BackgroundColor="#272A33"
                            Stroke="#7C3AED"
                            StrokeThickness="2"
                            StrokeShape="RoundRectangle 16">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCharacter1Selected" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                            <Image Source="character.png" HeightRequest="72" WidthRequest="72" Aspect="AspectFit" />
                            <Label Text="Character 1" FontFamily="PoppinsSemiBold" TextColor="#F4F4F5" HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </Border>
                    <Border x:Name="Character2Option"
                            Grid.Column="1"
                            Padding="14,10"
                            BackgroundColor="#1F2128"
                            Stroke="#3F4350"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 16">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCharacter2Selected" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                            <Image Source="character2.png" HeightRequest="72" WidthRequest="72" Aspect="AspectFit" />
                            <Label Text="Character 2" FontFamily="PoppinsSemiBold" TextColor="#F4F4F5" HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <Label Text="Capture and toggle chat"
                       FontFamily="PoppinsSemiBold"
                       TextColor="#D4D4D8" />
                <Border BackgroundColor="#1F2128" Stroke="#3F4350" StrokeShape="RoundRectangle 12">
                    <Entry x:Name="ToggleHotkeyEntry"
                           Placeholder="Alt+Z"
                           TextColor="#E4E4E7"
                           PlaceholderColor="#9CA3AF"
                           BackgroundColor="Transparent" />
                </Border>

                <Label Text="Resume chat without capture"
                       FontFamily="PoppinsSemiBold"
                       TextColor="#D4D4D8" />
                <Border BackgroundColor="#1F2128" Stroke="#3F4350" StrokeShape="RoundRectangle 12">
                    <Entry x:Name="ResumeHotkeyEntry"
                           Placeholder="Alt+Shift+Z"
                           TextColor="#E4E4E7"
                           PlaceholderColor="#9CA3AF"
                           BackgroundColor="Transparent" />
                </Border>

                <Label x:Name="SettingsStatusLabel"
                       IsVisible="False"
                       FontSize="13"
                       TextColor="#FCA5A5" />

                <HorizontalStackLayout Spacing="10" HorizontalOptions="End">
                    <Button Text="Cancel" Clicked="OnSettingsCancelClicked"
                            BackgroundColor="#272A33" TextColor="#D4D4D8" CornerRadius="12" />
                    <Button Text="Save shortcuts" Clicked="OnSettingsSaveClicked"
                            BackgroundColor="#7C3AED" TextColor="#FAFAFA" CornerRadius="12" />
                </HorizontalStackLayout>
            </VerticalStackLayout>
        </Border>
    </Grid>

</ContentPage>
